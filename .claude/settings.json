      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm --version)",
      "Bash(npm search:*)",
      "Bash(npm view:*)",
      "Bash(npx biome:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx vite:*)",
      "Bash(npx vitest:*)",
      "Bash(pnpm:*)",
      "Bash(pwd:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Read(//tmp/claude-1000/**)",
      "Read(//tmp/claude-moves/**)",
      "Skill(update-config)",
      "WebFetch",
      "WebFetch(domain:adwitr.itch.io)",
      "WebFetch(domain:anima-nel.itch.io)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:api.pixellab.ai)",
      "WebFetch(domain:backblaze.pixellab.ai)",
      "WebFetch(domain:crusenho.itch.io)",
      "WebFetch(domain:docs.godotengine.org)",
      "WebFetch(domain:eeveeexpo.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:itch.io)",
      "WebFetch(domain:kenney.nl)",
      "WebFetch(domain:mounirtohami.itch.io)",
      "WebFetch(domain:opengameart.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:sprites.pmdcollab.org)",
      "WebFetch(domain:veekun.com)",
      "WebFetch(domain:wiki.pmdo.pmdcollab.org)",
      "WebFetch(domain:www.pokecommunity.com)",
      "WebFetch(domain:www.pokencyclopedia.info)",
      "WebFetch(domain:www.spriters-resource.com)",
      "WebSearch",
      "mcp__context7",
      "mcp__git",
      "mcp__github",
