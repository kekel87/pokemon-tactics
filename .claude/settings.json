      "Bash(git branch -d:*)",
      "Bash(git checkout:*)",
      "Bash(git clean:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git mv:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git stash drop:*)",
      "Bash(git tag -d:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(scp:*)",
      "Bash(ssh:*)",
