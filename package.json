{
  "name": "pokemon-tactics",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @pokemon-tactic/app dev",
    "dev:sandbox": "pnpm --filter @pokemon-tactic/app dev:sandbox",
    "dev:map": "pnpm --filter @pokemon-tactic/app dev:map",
    "build": "pnpm -r build",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:scenario": "vitest run --project scenario",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --parallel run typecheck",
    "extract-sprites": "tsx scripts/extract-sprites.ts",
    "pack-sprites": "tsx scripts/pack-sprites.ts",
    "download-status-icons": "tsx scripts/download-status-icons.ts",
    "replay:generate": "tsx scripts/generate-golden-replay.ts",
    "data:update": "pnpm --filter @pokemon-tactic/data run data:update",
    "data:update:skip-fetch": "pnpm --filter @pokemon-tactic/data run data:update:skip-fetch",
    "data:update:fetch-only": "pnpm --filter @pokemon-tactic/data run data:update:fetch-only",
    "data:diff": "pnpm --filter @pokemon-tactic/data run data:diff"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-xml-parser": "^5.10.1",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
