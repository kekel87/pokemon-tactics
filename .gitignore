dist/
build/
*.tsbuildinfo

# Vite
.vite/

# Test coverage
coverage/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Logs
*.log

# Claude Code local settings
.claude/settings.local.json
.claude/*.lock

# Worktrees parallèles (sessions Claude //) + port Vite par worktree
.worktrees/
.worktree-port

# Reference data build cache (regeneratable)
packages/data/.cache/

# Per-Pokemon sprite source folders (plan 135): editable source/cache emitted by
# `pnpm extract-sprites`, regeneratable from PMDCollab. Only the 3-file bundle ships
# + is committed (sprites.bin, sprites-manifest.json, portraits.png). Run once to
# untrack the legacy folders: `git rm -r --cached packages/app/public/assets/sprites/pokemon`
packages/app/public/assets/sprites/pokemon/

# Reference screenshots (local only)
docs/references/

# Tiles workspace (tests, temporaires)
tiles/

# Promo / diffusion notes (local only — stratégie privée, repo public)
docs/promo-channels.md

# Shared screenshots (échanges humain/Claude)
share/

# Visual tester screenshots (generated by visual-tester agent)
screenshots/
.screenshots/

.playwright-mcp/
# Playwright e2e artefacts (plan 127)
test-results/
playwright-report/
blob-report/
.last-run.json
wiki/
.mcp.json

# Tiled editor user state (per-workstation, not shared)
*.tiled-session

# Serena MCP (cache et config locale, project.yml est versionné)
.serena/cache/
.serena/project.local.yml

# Understand Anything (fichiers intermédiaires — knowledge-graph.json est versionné)
.understand-anything/intermediate/
.understand-anything/tmp/

# Claude Code state files (local only)
.itch-feedback-last-run
.claude/scheduled_tasks.lock

# Scripts de probe e2e jetables (jamais commités)
_*.mjs

# Exports voxel intermédiaires (Goxel → .gltf) : régénérables, artefact runtime = .glb (public/),
# sources = .gox (assets-src/voxel/goxel/). On ne commite pas l'étape .gltf.
assets-src/voxel/*.gltf
